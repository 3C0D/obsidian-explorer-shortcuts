{
  "name": "explorer-shortcuts",
  "version": "1.6.6",
  "description": "Open successive files navigating with arrows ↑↓ over the explorer and use shortcuts for current actions on files/folders (cut, paste, copy, rename, delete, etc).",
  "main": "main.js",
  "scripts": {
    "start": "yarn install && yarn dev",
    "dev": "npx tsx scripts/esbuild.config.ts",
    "build": "tsc -noEmit -skipLibCheck && npx tsx scripts/esbuild.config.ts production",
    "real": "npx tsx scripts/esbuild.config.ts production real",
    "acp": "npx tsx scripts/acp.ts",
    "bacp": "npx tsx scripts/acp.ts -b",
    "release": "npx tsx scripts/release.ts",
    "update-version": "npx tsx scripts/update-version.ts",
    "v": "npx tsx scripts/update-version.ts",
    "r": "npx tsx scripts/release.ts",
    "help": "npx tsx scripts/help.ts",
    "h": "npx tsx scripts/help.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prettier": "npx prettier --check '**/*.{ts,json}'",
    "prettier:fix": "npx prettier --write '**/*.{ts,json}'"
  },
  "keywords": [],
  "author": "3C0D",
  "license": "MIT",
  "devDependencies": {
    "@types/eslint": "latest",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "latest",
    "@types/semver": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "builtin-modules": "latest",
    "cross-env": "^7.0.3",
    "dedent": "latest",
    "dotenv": "latest",
    "esbuild": "latest",
    "eslint": "latest",
    "eslint-import-resolver-typescript": "latest",
    "fs-extra": "^11.2.0",
    "jiti": "latest",
    "json-stringify-pretty-compact": "^4.0.0",
    "obsidian": "*",
    "obsidian-plugin-config": "latest",
    "obsidian-typings": "latest",
    "prettier": "latest",
    "semver": "latest",
    "tslib": "2.4.0",
    "tsx": "latest",
    "typescript": "^5.8.2"
  },
  "engines": {
    "npm": "please-use-yarn",
    "yarn": ">=1.22.0"
  },
  "type": "module"
}